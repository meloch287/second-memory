# Скопируйте в .env и заполните. Файл .env в git не попадает.

# Текстовый ИИ: ответы друга, саммари, факты для RAG.
# Любой OpenAI-совместимый провайдер; по умолчанию GonkaGate.
AI_API_KEY=
AI_BASE_URL=https://api.gonkagate.com/v1
AI_MODEL=moonshotai/kimi-k2.6

# Аудио-ИИ: расшифровка голосовых в Telegram (нужна мультимодальная модель).
AI_AUDIO_API_KEY=
AI_AUDIO_BASE_URL=https://api.polza.ai/v1
AI_AUDIO_MODEL=google/gemini-2.5-flash-lite

# Telegram-бот (токен у @BotFather). Пусто - бот выключен.
TELEGRAM_BOT_TOKEN=

# Порт веб-интерфейса
# PORT=8790
