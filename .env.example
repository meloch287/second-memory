# Скопируйте в .env и заполните. Файл .env в git не попадает.

# ИИ (саммари, ответы на вопросы, расшифровка голосовых в Telegram).
# Любой OpenAI-совместимый провайдер; по умолчанию — polza.ai.
AI_API_KEY=
AI_BASE_URL=https://api.polza.ai/v1
AI_MODEL=google/gemini-2.5-flash-lite

# Telegram-бот (токен у @BotFather). Пусто — бот выключен.
TELEGRAM_BOT_TOKEN=

# Порт веб-интерфейса
# PORT=8790
